{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "App Movil",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/app"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontends"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Frontend Web",
      "type": "shell",
      "command": "npm start",
      //"command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/fe"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontends"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Generar APK App Movil",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "npm run build && npx cap sync android && cd android && gradlew.bat assembleDebug"
      ],
      "options": {
        "cwd": "${workspaceFolder}/app"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "apk"
      }
    }
  ]
}